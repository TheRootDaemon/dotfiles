{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "version": 3,
    "palette": {
        "pine": "#3e8fb0",
        "foam": "#9ccfd8",
        "love": "#eb6f92",
        "rose": "#ebbcba",
        "text": "#e0def4"
    },
    "blocks": [
        {
            "type": "prompt",
            "alignment": "left",
            "segments": [
                {
                    "type": "path",
                    "style": "plain",
                    "foreground": "p:pine",
                    "template": " {{ .Path }}",
                    "properties": {
                        "style": "full"
                    },
                    "font_style": "bold"
                },
                {
                    "type": "git",
                    "style": "plain",
                    "foreground": "p:rose",
                    "template": " <p:text>git:(</>{{ .HEAD }}<p:foam>{{ if .Working.Changed }} ~{{ end }}{{ if .Staging.Changed }} +{{ end }}{{ if .Ahead }} +{{ .Ahead }}{{ end }}{{ if .Behind }} -{{ .Behind }}{{ end }}</><p:text>)</>",
                    "properties": {
                        "branch_icon": "",
                        "fetch_status": true,
                        "display_status": true,
                        "display_stash_count": true
                    },
                    "font_style": "bold"
                },
                {
                    "type": "text",
                    "style": "plain",
                    "foreground": "p:foam",
                    "template": " :",
                    "font_style": "bold"
                },
                {
                    "type": "status",
                    "style": "plain",
                    "foreground": "p:love",
                    "template": " \u2717",
                    "font_style": "bold"
                }
            ]
        }
    ],
    "final_space": true
}
